# Application
SECRET_KEY=change-me-use-openssl-rand-hex-32
INSTITUTION_NAME="Research Institution"
MAX_ACTIVE_DATASETS=1
SESSION_RETENTION_DAYS=90

# Database (used by backend in Docker via docker-compose env)
DATABASE_URL=postgresql+asyncpg://hra:hra_secret@db:5432/hra

# LLM — Gemini (default)
GEMINI_API_KEY=your-gemini-api-key
LLM_MODEL=gemini/gemini-2.5-flash

# LLM — Local model (set LOCAL_MODEL_ENABLED=true to use)
LOCAL_MODEL_ENABLED=false
OLLAMA_API_BASE=http://host.docker.internal:11434
LLM_MODEL_LOCAL=ollama/llama3

# Auth
ALLOW_REGISTRATION=false

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
